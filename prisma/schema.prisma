// Gestion financière FTM — schema aligned with MVP architecture plan (France)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Profil applicatif (id = auth.users.id côté Supabase Auth) ---

model User {
  id             String             @id @db.Uuid
  email          String             @unique
  name           String?
  image          String?
  isAdmin        Boolean            @default(false)
  memberships    UserOrganization[]
  projectMembers ProjectMember[]
  auditLogs      AuditLog[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  ftmDocuments   FtmDocument[]
}

// --- Organizations & projects ---

model Organization {
  id                 String                     @id @default(uuid()) @db.Uuid
  name               String
  slug               String?                    @unique
  userOrganizations  UserOrganization[]
  projectMembers     ProjectMember[]
  ftmsConcerned      FtmConcernedOrganization[]
  ftmLots            FtmLot[]
  quoteSubmissions   FtmQuoteSubmission[]
  situations         SituationTravaux[]
  contractSettings   CompanyContractSettings[]
  forecasts          Forecast[]
  penalties          Penalty[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  ftmDocuments       FtmDocument[]
  projectLots        ProjectLotOrganization[]
  targetChatMessages FtmChatMessage[]
}

model UserOrganization {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  organizationId String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Project {
  id               String                   @id @default(uuid()) @db.Uuid
  name             String
  code             String?
  baseContract     BaseContract?
  lots             ProjectLot[]
  members          ProjectMember[]
  ftms             FtmRecord[]
  ftmDemands       FtmDemand[]
  permissionGroups ProjectPermissionGroup[]
  situations       SituationTravaux[]
  contractSettings CompanyContractSettings[]
  forecasts        Forecast[]
  penalties        Penalty[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model ProjectLot {
  id            String                   @id @default(uuid()) @db.Uuid
  projectId     String                   @db.Uuid
  label         String
  description   String?                  @db.Text
  project       Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizations ProjectLotOrganization[]

  @@index([projectId])
}

model ProjectLotOrganization {
  id                   String       @id @default(uuid()) @db.Uuid
  projectLotId         String       @db.Uuid
  organizationId       String       @db.Uuid
  montantMarcheHtCents BigInt
  projectLot           ProjectLot   @relation(fields: [projectLotId], references: [id], onDelete: Cascade)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectLotId, organizationId])
}

enum ProjectRole {
  MOA
  MOE
  ENTREPRISE
}

model ProjectMember {
  id                  String                            @id @default(uuid()) @db.Uuid
  userId              String                            @db.Uuid
  projectId           String                            @db.Uuid
  organizationId      String                            @db.Uuid
  role                ProjectRole
  permissionGroupId   String?                           @db.Uuid
  user                User                              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project             Project                           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization        Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissionGroup     ProjectPermissionGroup?           @relation(fields: [permissionGroupId], references: [id])
  initiatedFtms       FtmRecord[]                       @relation("FtmInitiator")
  ftmDemands          FtmDemand[]
  designatedMoaFtms   FtmRecord[]                       @relation("FtmDesignatedMoa")
  moaEtudesDecisions  FtmRecord[]                       @relation("FtmMoaEtudesDecider")
  cancelledFtms       FtmRecord[]                       @relation("FtmCanceller")
  chatMessages        FtmChatMessage[]
  reviews             FtmReview[]
  capabilityOverrides    ProjectMemberCapabilityOverride[]
  rejectedDemands        FtmDemand[]                       @relation("FtmDemandRejectedBy")
  submittedSituations    SituationTravaux[]                @relation("SituationSubmitter")
  moeReviewedSituations  SituationTravaux[]                @relation("SituationMoeReviewer")
  moaValidatedSituations SituationTravaux[]                @relation("SituationMoaValidator")
  situationReviews       SituationReview[]                 @relation("SituationReviewMember")
  submittedForecasts     Forecast[]                        @relation("ForecastSubmitter")
  moeReviewedForecasts   Forecast[]                        @relation("ForecastMoeReviewer")
  moaValidatedForecasts  Forecast[]                        @relation("ForecastMoaValidator")
  forecastReviews        ForecastReview[]                  @relation("ForecastReviewMember")
  createdPenalties       Penalty[]                         @relation("PenaltyCreator")
  penaltyReviews         PenaltyReview[]                   @relation("PenaltyReviewMember")

  @@unique([userId, projectId, organizationId])
  @@index([projectId])
  @@index([userId])
}

model BaseContract {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @unique @db.Uuid
  label         String
  amountHtCents BigInt
  signatureDate DateTime?
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// --- RBAC (groups + deny-wins overrides) ---

model ProjectPermissionGroup {
  id           String                             @id @default(uuid()) @db.Uuid
  projectId    String                             @db.Uuid
  name         String
  project      Project                            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  capabilities ProjectPermissionGroupCapability[]
  members      ProjectMember[]
  createdAt    DateTime                           @default(now())
}

enum Capability {
  VIEW_GLOBAL_FINANCE
  VIEW_OWN_SCOPE
  CREATE_FTM
  APPROVE_FTM_CREATION_MOE
  EDIT_ETUDES
  INVITE_ETUDES_PARTICIPANT
  VALIDATE_ETUDES_MOA
  SET_DEADLINES_AFTER_ETUDES
  POST_FTM_CHAT
  SUBMIT_QUOTE
  ANALYZE_QUOTE_MOE
  FINAL_VALIDATE_QUOTE_MOA
  ADMIN_PROJECT_PERMISSIONS
  SUBMIT_SITUATION
  REVIEW_SITUATION_MOE
  VALIDATE_SITUATION_MOA
  CONFIGURE_CONTRACT_SETTINGS
  SUBMIT_FORECAST
  REVIEW_FORECAST_MOE
  VALIDATE_FORECAST_MOA
  CREATE_PENALTY
  VALIDATE_PENALTY_MOA
  CONTEST_PENALTY
}

model ProjectPermissionGroupCapability {
  id         String                 @id @default(uuid()) @db.Uuid
  groupId    String                 @db.Uuid
  capability Capability
  group      ProjectPermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, capability])
}

model ProjectMemberCapabilityOverride {
  id              String        @id @default(uuid()) @db.Uuid
  projectMemberId String        @db.Uuid
  capability      Capability
  allowed         Boolean
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, capability])
}

// --- FTM dossier ---

enum FtmPhase {
  ETUDES
  QUOTING
  ANALYSIS
  MOA_FINAL
  CANCELLED
  ACCEPTED
}

enum ModificationSource {
  MOA
  MOE
  ALEAS_EXECUTION
}


enum MoaEtudesDecision {
  PENDING
  APPROVED
  DECLINED
}

model FtmRecord {
  id                 String             @id @default(uuid()) @db.Uuid
  projectId          String             @db.Uuid
  number             Int                @default(0)
  phase              FtmPhase           @default(ETUDES)
  title              String
  fromDemandId       String?            @db.Uuid
  fromDemand         FtmDemand?         @relation(fields: [fromDemandId], references: [id])
  modificationSource       ModificationSource

  initiatorProjectMemberId String        @db.Uuid
  initiator                ProjectMember @relation("FtmInitiator", fields: [initiatorProjectMemberId], references: [id])


  etudesDescription String? @db.Text

  moaEtudesDecision    MoaEtudesDecision @default(PENDING)
  moaEtudesDecidedById String?           @db.Uuid
  moaEtudesDecidedBy   ProjectMember?    @relation("FtmMoaEtudesDecider", fields: [moaEtudesDecidedById], references: [id])
  moaEtudesDecidedAt   DateTime?
  moaEtudesComment     String?           @db.Text

  requestedMoeResponseDate DateTime?
  documents                FtmDocument[]

  designatedMoaValidatorId String?        @db.Uuid
  designatedMoaValidator   ProjectMember? @relation("FtmDesignatedMoa", fields: [designatedMoaValidatorId], references: [id])

  concernedOrgs    FtmConcernedOrganization[]
  lots             FtmLot[]
  invitations      FtmParticipantInvitation[]
  chatMessages     FtmChatMessage[]
  quoteSubmissions FtmQuoteSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cancellationReason   String?        @db.Text
  cancelledById        String?        @db.Uuid
  cancelledBy          ProjectMember? @relation("FtmCanceller", fields: [cancelledById], references: [id])
  cancelledAt          DateTime?
  preCancellationPhase FtmPhase?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
  @@index([phase])
}

model FtmConcernedOrganization {
  id                    String       @id @default(uuid()) @db.Uuid
  ftmId                 String       @db.Uuid
  organizationId        String       @db.Uuid
  dateLimiteDevis       DateTime?
  description           String?      @db.Text
  reminderFrequencyDays Int?
  lastReminderAt        DateTime?
  ftm                   FtmRecord    @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([ftmId, organizationId])
}

model FtmLot {
  id                 String               @id @default(uuid()) @db.Uuid
  ftmId              String               @db.Uuid
  organizationId     String?              @db.Uuid
  lotLabel           String?
  descriptionTravaux String               @db.Text
  ftm                FtmRecord            @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  organization       Organization?        @relation(fields: [organizationId], references: [id])
  quoteSubmissions   FtmQuoteSubmission[]

  @@index([ftmId, organizationId])
}

enum ParticipantInviteRole {
  BUREAU_ETUDES
  OTHER
}

model FtmParticipantInvitation {
  id           String                @id @default(uuid()) @db.Uuid
  ftmId        String                @db.Uuid
  email        String
  userId       String?               @db.Uuid
  tokenHash    String
  expiresAt    DateTime
  role         ParticipantInviteRole @default(OTHER)
  contribution String?               @db.Text
  consumedAt   DateTime?
  ftm          FtmRecord             @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  createdAt    DateTime              @default(now())

  @@index([ftmId])
}

model FtmChatMessage {
  id                    String         @id @default(uuid()) @db.Uuid
  ftmId                 String         @db.Uuid
  targetOrganizationId  String?        @db.Uuid
  authorProjectMemberId String?        @db.Uuid
  guestInvitationId     String?        @db.Uuid
  body                  String         @db.Text
  createdAt             DateTime       @default(now())
  ftm                   FtmRecord      @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  targetOrganization    Organization?  @relation(fields: [targetOrganizationId], references: [id], onDelete: Cascade)
  author                ProjectMember? @relation(fields: [authorProjectMemberId], references: [id])

  @@index([ftmId])
  @@index([targetOrganizationId])
}

model FtmQuoteSubmission {
  id             String       @id @default(uuid()) @db.Uuid
  ftmId          String       @db.Uuid
  ftmLotId       String       @db.Uuid
  organizationId String       @db.Uuid
  indice         Int
  amountHtCents  BigInt
  quoteNumber    String?
  documentUrl    String?
  documentName   String?
  submittedAt    DateTime     @default(now())
  ftm            FtmRecord    @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  ftmLot         FtmLot       @relation(fields: [ftmLotId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews        FtmReview[]

  @@unique([ftmLotId, organizationId, indice])
  @@index([ftmId])
}

enum ReviewContext {
  MOE_ANALYSIS
  MOA_FINAL_QUOTE
}

enum ReviewDecision {
  ACCEPT
  RESEND_CORRECTION
  DECLINE
}

enum DeclineScope {
  WHOLE_FTM
  THIS_COMPANY_ONLY
}

model FtmReview {
  id                      String             @id @default(uuid()) @db.Uuid
  quoteSubmissionId       String             @db.Uuid
  context                 ReviewContext
  reviewerProjectMemberId String             @db.Uuid
  decision                ReviewDecision
  comment                 String             @db.Text
  declineScope            DeclineScope?
  decidedAt               DateTime           @default(now())
  quoteSubmission         FtmQuoteSubmission @relation(fields: [quoteSubmissionId], references: [id], onDelete: Cascade)
  reviewer                ProjectMember      @relation(fields: [reviewerProjectMemberId], references: [id])

  @@index([quoteSubmissionId])
}

// --- Situation travaux ---

enum SituationStatus {
  DRAFT
  SUBMITTED
  MOE_CORRECTION
  MOE_APPROVED
  MOA_APPROVED
  MOE_REFUSED
  MOA_REFUSED
}

enum PenaltyType {
  NONE
  FREE_AMOUNT
  DAILY_RATE
}

model CompanyContractSettings {
  id             String  @id @default(uuid()) @db.Uuid
  projectId      String  @db.Uuid
  organizationId String  @db.Uuid

  retenueGarantieActive     Boolean  @default(false)
  retenueGarantiePercent    Decimal? @db.Decimal(5, 2)

  avanceTravauxAmountCents        BigInt?
  avanceTravauxRefundStartMonth   Int?
  avanceTravauxRefundStartPercent Decimal? @db.Decimal(5, 2)
  avanceTravauxRefundInstallments Int?

  penaltyType           PenaltyType @default(NONE)
  penaltyDailyRateCents BigInt?

  forecastWaived Boolean @default(false)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, organizationId])
  @@index([projectId])
}

model SituationTravaux {
  id             String          @id @default(uuid()) @db.Uuid
  projectId      String          @db.Uuid
  organizationId String          @db.Uuid
  numero         Int
  periodLabel    String
  status         SituationStatus @default(DRAFT)

  createdAt      DateTime        @default(now())

  // Company submission
  cumulativeAmountHtCents BigInt
  documentUrl             String?
  documentName            String?
  submittedById           String?   @db.Uuid
  submittedAt             DateTime?

  // MOE review
  moeStatus                String?
  moeReviewedById          String?   @db.Uuid
  moeReviewedAt            DateTime?
  moeComment               String?   @db.Text
  moeAdjustedAmountHtCents BigInt?
  penaltyType              PenaltyType?
  penaltyDelayDays         Int?
  penaltyAmountCents       BigInt?

  // Company correction response
  correctionComment String? @db.Text

  // MOA validation
  moaStatus        String?
  moaValidatedById String?   @db.Uuid
  moaValidatedAt   DateTime?
  moaComment       String?   @db.Text

  // Financial snapshot (frozen at MOA approval)
  acceptedCumulativeHtCents        BigInt?
  previousCumulativeHtCents        BigInt?
  periodNetBeforeDeductionsHtCents BigInt?
  retenueGarantieAmountCents       BigInt?
  avanceTravauxRemboursementCents  BigInt?
  netAmountHtCents                 BigInt?

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy    ProjectMember? @relation("SituationSubmitter", fields: [submittedById], references: [id])
  moeReviewedBy  ProjectMember? @relation("SituationMoeReviewer", fields: [moeReviewedById], references: [id])
  moaValidatedBy ProjectMember? @relation("SituationMoaValidator", fields: [moaValidatedById], references: [id])
  reviews        SituationReview[]
  penalties      Penalty[]

  @@unique([projectId, organizationId, numero])
  @@index([projectId])
  @@index([organizationId])
}

// --- Situation review events ---

enum SituationEventType {
  SUBMITTED
  MOE_REVIEWED
  MOA_VALIDATED
}

model SituationReview {
  id          String             @id @default(uuid()) @db.Uuid
  situationId String             @db.Uuid
  memberId    String             @db.Uuid
  eventType   SituationEventType
  createdAt   DateTime           @default(now())

  // SUBMITTED
  amountHtCents     BigInt?
  documentName      String?
  correctionComment String?      @db.Text

  // MOE_REVIEWED
  decision              String?
  comment               String?  @db.Text
  adjustedAmountHtCents BigInt?
  penaltyAmountCents    BigInt?

  // MOA_VALIDATED reuses decision + comment

  situation SituationTravaux @relation(fields: [situationId], references: [id], onDelete: Cascade)
  member    ProjectMember    @relation("SituationReviewMember", fields: [memberId], references: [id])

  @@index([situationId, createdAt])
}

// --- Forecast (Prévisionnel) ---

enum ForecastStatus {
  DRAFT
  SUBMITTED
  MOE_CORRECTION
  MOE_APPROVED
  MOA_APPROVED
  MOE_REFUSED
  MOA_REFUSED
}

enum ForecastEventType {
  SUBMITTED
  MOE_REVIEWED
  MOA_VALIDATED
}

model Forecast {
  id             String         @id @default(uuid()) @db.Uuid
  projectId      String         @db.Uuid
  organizationId String         @db.Uuid
  indice         Int
  status         ForecastStatus @default(DRAFT)
  createdAt      DateTime       @default(now())

  submittedById     String?    @db.Uuid
  submittedAt       DateTime?
  correctionComment String?    @db.Text

  moeStatus       String?
  moeReviewedById String?    @db.Uuid
  moeReviewedAt   DateTime?
  moeComment      String?    @db.Text

  moaStatus        String?
  moaValidatedById String?    @db.Uuid
  moaValidatedAt   DateTime?
  moaComment       String?    @db.Text

  entries ForecastEntry[]
  reviews ForecastReview[]

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy    ProjectMember? @relation("ForecastSubmitter",    fields: [submittedById],    references: [id])
  moeReviewedBy  ProjectMember? @relation("ForecastMoeReviewer",  fields: [moeReviewedById],  references: [id])
  moaValidatedBy ProjectMember? @relation("ForecastMoaValidator", fields: [moaValidatedById], references: [id])

  @@unique([projectId, organizationId, indice])
  @@index([projectId])
  @@index([organizationId])
}

model ForecastEntry {
  id                   String   @id @default(uuid()) @db.Uuid
  forecastId           String   @db.Uuid
  periodLabel          String
  plannedAmountHtCents BigInt

  forecast Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, periodLabel])
  @@index([forecastId])
}

model ForecastReview {
  id         String            @id @default(uuid()) @db.Uuid
  forecastId String            @db.Uuid
  memberId   String            @db.Uuid
  eventType  ForecastEventType
  createdAt  DateTime          @default(now())

  decision          String?
  comment           String?  @db.Text
  correctionComment String?  @db.Text

  forecast Forecast      @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  member   ProjectMember @relation("ForecastReviewMember", fields: [memberId], references: [id])

  @@index([forecastId, createdAt])
}

// --- Audit ---

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
}

model FtmDocument {
  id             String   @id @default(uuid()) @db.Uuid
  ftmId          String?  @db.Uuid
  ftmDemandId    String?  @db.Uuid
  organizationId String?  @db.Uuid
  name           String
  url            String
  uploadedById   String   @db.Uuid
  createdAt      DateTime @default(now())

  ftm          FtmRecord?    @relation(fields: [ftmId], references: [id], onDelete: Cascade)
  ftmDemand    FtmDemand?    @relation(fields: [ftmDemandId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])

  @@index([ftmId])
  @@index([ftmDemandId])
}

model FtmDemand {
  id                       String             @id @default(uuid()) @db.Uuid
  projectId                String             @db.Uuid
  project                  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  initiatorProjectMemberId String             @db.Uuid
  initiator                ProjectMember      @relation(fields: [initiatorProjectMemberId], references: [id])
  
  title                    String
  description              String             @db.Text
  requestedMoeResponseDate DateTime?
  status                   String             @default("DRAFT") // DRAFT, PENDING_MOE, APPROVED, REJECTED
  
  rejectedByMemberId       String?            @db.Uuid
  rejectedBy               ProjectMember?     @relation("FtmDemandRejectedBy", fields: [rejectedByMemberId], references: [id])
  rejectedAt               DateTime?
  
  documents                FtmDocument[]
  ftmRecords               FtmRecord[]

  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

// --- Penalties (Pénalités) ---

enum PenaltyStatus {
  DRAFT
  SUBMITTED
  MOA_APPROVED
  MOA_REFUSED
  CONTESTED
  CANCELLED
  MAINTAINED
}

enum PenaltyAmountType {
  FIXED
  PCT_BASE_MARCHE
  PCT_ACTUAL_MARCHE
}

enum PenaltyApplicationTarget {
  SITUATION
  DGD
}

enum PenaltyReviewAction {
  SUBMITTED
  MOA_APPROVED
  MOA_REFUSED
  CONTESTED
  CANCELLED
  MAINTAINED
}

model Penalty {
  id             String                   @id @default(uuid()) @db.Uuid
  projectId      String                   @db.Uuid
  organizationId String                   @db.Uuid

  label          String
  justification  String                   @db.Text

  // Amount: inputValue is cents for FIXED, basis points (×100) for PCT types
  amountType        PenaltyAmountType
  inputValue        BigInt
  // Frozen at submission time; null until then
  frozenAmountCents BigInt?

  applicationTarget PenaltyApplicationTarget @default(SITUATION)
  situationId       String?                  @db.Uuid

  status            PenaltyStatus            @default(DRAFT)

  createdByMemberId String                   @db.Uuid

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  situation   SituationTravaux? @relation(fields: [situationId], references: [id])
  createdBy   ProjectMember    @relation("PenaltyCreator", fields: [createdByMemberId], references: [id])
  reviews     PenaltyReview[]

  @@index([projectId])
  @@index([organizationId])
  @@index([situationId])
}

model PenaltyReview {
  id        String              @id @default(uuid()) @db.Uuid
  penaltyId String              @db.Uuid
  memberId  String              @db.Uuid
  action    PenaltyReviewAction
  comment   String?             @db.Text
  createdAt DateTime            @default(now())

  penalty Penalty       @relation(fields: [penaltyId], references: [id], onDelete: Cascade)
  member  ProjectMember @relation("PenaltyReviewMember", fields: [memberId], references: [id])

  @@index([penaltyId, createdAt])
}
